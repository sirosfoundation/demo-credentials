{
  "vct": "https://registry.siros.org/sirosfoundation/demo_student_id.vctm.json",
  "name": "Student ID",
  "description": "Demo credential for a student ID card",
  "display": [
    {
      "locale": "en-US",
      "name": "Student ID",
      "description": "Demo credential for a student ID card",
      "rendering": {
        "simple": {
          "background_color": "#F09B3C",
          "text_color": "#36306F"
        },
        "svg_templates": [
          {
            "uri": "data:image/svg+xml;base64,"
          }
        ]
      }
    }
  ],
  "claims": [
    {
      "path": ["family_name"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "family_name",
      "display": [
        {
          "locale": "en-US",
          "label": "Last name",
          "description": "Current last name(s) or surname(s)."
        }
      ]
    },
    {
      "path": ["given_name"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "given_name",
      "display": [
        {
          "locale": "en-US",
          "label": "First name",
          "description": "Current first name(s), including middle name(s) if applicable."
        }
      ]
    },
    {
      "path": ["birthdate"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "birth_date",
      "display": [
        {
          "locale": "en-US",
          "label": "Date of birth",
          "description": "Full birth date (day, month, year)."
        }
      ]
    },
    {
      "path": ["picture"],
      "mandatory": false,
      "sd": "always",
      "display": [
        {
          "locale": "en-US",
          "label": "Picture",
          "description": "Portrait image of the person."
        }
      ]
    },
    {
      "path": ["email"],
      "mandatory": false,
      "sd": "always",
      "display": [
        {
          "locale": "en-US",
          "label": "Email",
          "description": "Person's email address."
        }
      ]
    },
    {
      "path": ["date_of_expiry"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "expiry_date",
      "display": [
        {
          "locale": "en-US",
          "label": "Expiry date",
          "description": "End date of the document's validity."
        }
      ]
    },
    {
      "path": ["issuer_name"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "issuer_name",
      "display": [
        {
          "locale": "en-US",
          "label": "Issuer name",
          "description": "Name of the issuing institution."
        }
      ]
    },
    {
      "path": ["school_name"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "school_name",
      "display": [
        {
          "locale": "en-US",
          "label": "School name",
          "description": "Name of the student's school."
        }
      ]
    },
    {
      "path": ["student_number"],
      "mandatory": true,
      "sd": "always",
      "svg_id": "student_number",
      "display": [
        {
          "locale": "en-US",
          "label": "Student number",
          "description": "Unique identifier for student assigned by the school."
        }
      ]
    }
  ]
}
