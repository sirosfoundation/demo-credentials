{
  "vct": "https://registry.siros.org/sirosfoundation/vctm_siros_id.json",
  "name": "Siros ID",
  "description": "A personal identity document issued by the Siros Foundation.",
  "$comment": "",
  "display": [
    {
      "locale": "en-US",
      "name": "Siros ID",
      "description": "Personal identity document issued by the Siros Foundation.",
      "rendering": {
        "simple": {
          "logo": {
            "uri": "https://raw.githubusercontent.com/dc4eu/vc/d5bcc09ad66fb8491d0694f48d60371fc6ac9e04/images/generic-diploma-card-svg-dc4eu-01.svg",
            "uri#integrity": "sha256-wLet7Ra2LR80J8oXFR9aoB902q8va1eSRhO0JA6apG8"
          },
          "background_color": "#1a365d",
          "text_color": "#ffffff"
        },
        "svg_templates": [
          {
            "uri": "data:image/svg+xml;base64,"
          }
        ]
      }
    }
  ],
  "claims": [
    {
      "path": ["given_name"],
      "sd": "always",
      "svg_id": "given_name",
      "display": [
        {
          "locale": "en-US",
          "label": "First name",
          "description": "Current first name(s), including middle name(s) if applicable."
        }
      ]
    },
    {
      "path": ["family_name"],
      "sd": "always",
      "svg_id": "family_name",
      "display": [
        {
          "locale": "en-US",
          "label": "Last name",
          "description": "Current last name(s) or surname(s)."
        }
      ]
    },
    {
      "path": ["birth_date"],
      "sd": "always",
      "svg_id": "birth_date",
      "display": [
        {
          "locale": "en-US",
          "label": "Date of birth",
          "description": "Full birth date (day, month, year)."
        }
      ]
    },
    {
      "path": ["nationality"],
      "sd": "always",
      "svg_id": "nationality",
      "display": [
        {
          "locale": "en-US",
          "label": "Nationality",
          "description": "Country or countries of nationality (two-letter ISO 3166-1 alpha-2 code)."
        }
      ]
    },
    {
      "path": ["sex"],
      "sd": "always",
      "svg_id": "sex",
      "display": [
        {
          "locale": "en-US",
          "label": "Sex",
          "description": "Recorded sex using ISO 5218 codes (1 = male, 2 = female, 0 = not known, 9 = not applicable)."
        }
      ]
    },
    {
      "path": ["portrait"],
      "sd": "always",
      "svg_id": "portrait",
      "display": [
        {
          "locale": "en-US",
          "label": "Portrait",
          "description": "Portrait photograph of the document holder."
        }
      ]
    },
    {
      "path": ["document_number"],
      "sd": "always",
      "svg_id": "document_number",
      "display": [
        {
          "locale": "en-US",
          "label": "Document number",
          "description": "Unique identifier of the identity document."
        }
      ]
    },
    {
      "path": ["issuing_country"],
      "sd": "never",
      "svg_id": "issuing_country",
      "display": [
        {
          "locale": "en-US",
          "label": "Issuing country",
          "description": "Country where the document was issued (two-letter ISO 3166-1 alpha-2 code)."
        }
      ]
    },
    {
      "path": ["expiry_date"],
      "sd": "never",
      "svg_id": "expiry_date",
      "display": [
        {
          "locale": "en-US",
          "label": "Expiry date",
          "description": "End date of the document's validity."
        }
      ]
    }
  ]
}
