{
  "vct": "https://registry.siros.org/sirosfoundation/demo_student_id.vctm.json",
  "name": "Student ID",
  "description": "Demo credential for a student ID card",
  "display": [
    {
      "locale": "en-US",
      "name": "Student ID",
      "description": "Demo credential for a student ID card",
      "rendering": {
        "simple": {
          "logo": {
            "uri": "data:image/png;base64,"
          },
          "background_color": "#F09B3C",
          "text_color": "#36306F"
        },
        "svg_templates": [
          {
            "uri": "data:image/svg+xml;base64,"
          }
        ]
      }
    }
  ],
  "claims": [
    {
      "path": [
        "family_name"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "Last name",
          "description": "Current last name(s) or surname(s)."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "family_name"
    },
    {
      "path": [
        "given_name"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "First name",
          "description": "Current first name(s), including middle name(s) if applicable."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "given_name"
    },
    {
      "path": [
        "birthdate"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "Date of birth",
          "description": "Full birth date (day, month, year)."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "birth_date"
    },
    {
      "path": [
        "date_of_expiry"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "Expiry date",
          "description": "End date of the document's validity."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "expiry_date"
    },
    {
      "path": [
        "issuer_name"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "Issuer name",
          "description": "Name of the issuing institution."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "issuer_name"
    },
    {
      "path": [
        "school_name"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "School name",
          "description": "Name of the student's school."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "school_name"
    },
    {
      "path": [
        "student_status"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "Student status",
          "description": "Status of student"
        }
      ],
      "sd": "always"
    },
    {
      "path": [
        "student_number"
      ],
      "display": [
        {
          "locale": "en-US",
          "label": "Student number",
          "description": "Unique identifier for student assigned by the school."
        }
      ],
      "mandatory": true,
      "sd": "always",
      "svg_id": "student_number"
    }
  ]
}